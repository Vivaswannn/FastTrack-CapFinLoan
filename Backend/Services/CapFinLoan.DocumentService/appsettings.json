{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost,1433;Database=CapFinLoan_Document;User Id=sa;Password=YOUR_DB_PASSWORD;TrustServerCertificate=True;Min Pool Size=5;Max Pool Size=100;"
  },
  "JwtSettings": {
    "SecretKey": "YOUR_JWT_SECRET_KEY",
    "Issuer": "CapFinLoan",
    "Audience": "CapFinLoanUsers",
    "ExpiryMinutes": 60
  },
  "DocumentStorage": {
    "BasePath": "Uploads/Documents"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/documentservice-.txt",
          "rollingInterval": "Day"
        }
      }
    ]
  },
  "AllowedHosts": "*"
}
