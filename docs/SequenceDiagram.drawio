    <!-- Message 1: Applicant → Frontend: Fill form -->
    <mxCell id="m1" value="1. Fill loan application form (4-step wizard)" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#1565c0;strokeWidth=2;endArrow=block;endFill=1;fontSize=11;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry"><mxPoint x="105" y="170" as="sourcePoint"/><mxPoint x="305" y="170" as="targetPoint"/></mxGeometry>
    </mxCell>

    <!-- Message 2: Frontend → Gateway -->
    <mxCell id="m2" value="2. POST /gateway/applications  {Bearer JWT}" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#1565c0;strokeWidth=2;endArrow=block;endFill=1;fontSize=11;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry"><mxPoint x="315" y="210" as="sourcePoint"/><mxPoint x="515" y="210" as="targetPoint"/></mxGeometry>
    </mxCell>

    <!-- Message 3: Gateway validates JWT -->
    <mxCell id="m3" value="3. Validate JWT token + check role" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#c62828;strokeWidth=1.5;endArrow=block;endFill=1;dashed=1;fontSize=11;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry"><mxPoint x="515" y="250" as="sourcePoint"/><mxPoint x="525" y="250" as="targetPoint"/><Array as="points"><mxPoint x="560" y="250"/><mxPoint x="560" y="270"/><mxPoint x="525" y="270"/></Array></mxGeometry>
    </mxCell>

    <!-- Message 4: Gateway → AppService -->
    <mxCell id="m4" value="4. Forward request → POST /api/applications" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#c62828;strokeWidth=2;endArrow=block;endFill=1;fontSize=11;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry"><mxPoint x="525" y="290" as="sourcePoint"/><mxPoint x="725" y="290" as="targetPoint"/></mxGeometry>
    </mxCell>

    <!-- Message 5: Validation -->
    <mxCell id="m5" value="5. FluentValidation on CreateLoanApplicationDto" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#2e7d32;strokeWidth=1.5;endArrow=block;endFill=1;dashed=1;fontSize=11;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry"><mxPoint x="725" y="330" as="sourcePoint"/><mxPoint x="735" y="330" as="targetPoint"/><Array as="points"><mxPoint x="770" y="330"/><mxPoint x="770" y="350"/><mxPoint x="735" y="350"/></Array></mxGeometry>
    </mxCell>

    <!-- Message 6: Save to DB -->
    <mxCell id="m6" value="6. INSERT LoanApplication (Status=Draft)" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#2e7d32;strokeWidth=2;endArrow=block;endFill=1;fontSize=11;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry"><mxPoint x="735" y="390" as="sourcePoint"/><mxPoint x="925" y="390" as="targetPoint"/></mxGeometry>
    </mxCell>

    <!-- Message 7: DB returns -->
    <mxCell id="m7" value="7. Return ApplicationId (Guid)" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#f57f17;strokeWidth=1.5;endArrow=open;endFill=0;dashed=1;fontSize=11;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry"><mxPoint x="925" y="430" as="sourcePoint"/><mxPoint x="735" y="430" as="targetPoint"/></mxGeometry>
    </mxCell>

    <!-- Message 8: Return to Frontend -->
    <mxCell id="m8" value="8. ApiResponseDto { success, data: {applicationId} }" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#2e7d32;strokeWidth=1.5;endArrow=open;endFill=0;dashed=1;fontSize=11;" edge="1" parent="1">
