    <!-- Message 9: Submit -->
    <mxCell id="m9" value="9. POST /gateway/applications/{id}/submit  {Bearer JWT}" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#1565c0;strokeWidth=2;endArrow=block;endFill=1;fontSize=11;" edge="1" parent="1">
