    <mxCell id="m11" value="11. Validate Draft→Submitted, INSERT StatusHistory" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#2e7d32;strokeWidth=1.5;endArrow=block;endFill=1;dashed=1;fontSize=11;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry"><mxPoint x="735" y="590" as="sourcePoint"/><mxPoint x="925" y="590" as="targetPoint"/></mxGeometry>
    </mxCell>

    <!-- Message 12: Publish event -->
    <mxCell id="m12" value="12. Publish LoanStatusChangedEvent (exchange: loan.events)" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#7b1fa2;strokeWidth=2;endArrow=block;endFill=1;fontSize=11;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry"><mxPoint x="735" y="625" as="sourcePoint"/><mxPoint x="1125" y="625" as="targetPoint"/></mxGeometry>
    </mxCell>

    <!-- Message 13: RabbitMQ delivers -->
    <mxCell id="m13" value="13. Deliver to loan.status.changed queue" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#7b1fa2;strokeWidth=2;endArrow=block;endFill=1;fontSize=11;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry"><mxPoint x="1135" y="655" as="sourcePoint"/><mxPoint x="1335" y="655" as="targetPoint"/></mxGeometry>
    </mxCell>

    <!-- Message 14: Send email -->
    <mxCell id="m14" value="14. Send email to applicant via MailKit (async)" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#2e7d32;strokeWidth=1.5;endArrow=block;endFill=1;dashed=1;fontSize=11;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry"><mxPoint x="1335" y="695" as="sourcePoint"/><mxPoint x="105" y="695" as="targetPoint"/></mxGeometry>
    </mxCell>

    <!-- Message 15: Return success -->
    <mxCell id="m15" value="15. ApiResponseDto { success: true, message: 'Application submitted' }" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#2e7d32;strokeWidth=2;endArrow=open;endFill=0;dashed=1;fontSize=11;" edge="1" parent="1">
