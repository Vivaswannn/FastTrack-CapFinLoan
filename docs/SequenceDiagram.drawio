    <mxCell id="sep1" value="— Applicant clicks Submit —" style="text;html=1;strokeColor=#bdbdbd;fillColor=#f5f5f5;align=center;fontSize=11;fontStyle=2;fontColor=#616161;" vertex="1" parent="1">
      <mxGeometry x="300" y="490" width="920" height="26" as="geometry"/>
