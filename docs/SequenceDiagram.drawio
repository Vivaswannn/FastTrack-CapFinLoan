    <!-- Message 10: Forward submit -->
    <mxCell id="m10" value="10. POST /api/applications/{id}/submit" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#c62828;strokeWidth=2;endArrow=block;endFill=1;fontSize=11;" edge="1" parent="1">
